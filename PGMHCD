if (aged.age <= 24 && aged.developmentTrait === "superstar") delta = progChance < 0.7 ? 1 : 0;
else if (aged.age <= 25 && ["superstar","star"].includes(aged.developmentTrait)) delta = progChance < 0.5 ? 1 : 0;
else if (aged.age <= 27) delta = progChance < 0.3 ? 1 : 0;
else if (aged.age >= 32) delta = progChance < 0.4 ? -1 : 0;
else if (aged.age >= 35) delta = progChance < 0.7 ? -1 : 0;

