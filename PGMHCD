1. SEEDED RNG  (mulberry32 — matches HCD engine)
   ───────────────────────────────────────────────────────────────── */
   const mulberry32 = (seed) => {
   let t = seed >>> 0;
   return () => {
   t += 0x6d2b79f5;
   let x = Math.imul(t ^ (t >>> 15), 1 | t);
   x ^= x + Math.imul(x ^ (x >>> 7), 61 | x);
   return ((x ^ (x >>> 14)) >>> 0) / 4294967296;
   };
   };
   const hashSeed = (…parts) => {
   let h = 2166136261;
   for (const p of parts) {
   for (let i = 0; i < String(p).length; i++) { h ^= String(p).charCodeAt(i); h = Math.imul(h, 16777619); }
   }
   return h >>> 0;
   };
   // Stateful helpers that thread seed automatically via a generator
   const makeRng = (seed) => mulberry32(seed);
   const rF = (rng, lo = 0, hi = 1) => lo + rng() * (hi - lo);
   const rI = (rng, lo, hi) => lo + Math.floor(rng() * (hi - lo + 1));
   const rPick = (rng, arr) => arr[Math.floor(rng() * arr.length)];
   const rBool = (rng, p) => rng() < p;
   const rNorm = (rng, mean, std) => { let s = 0; for (let i=0;i<6;i++) s+=rng(); return Math.round((s-3)*std+mean); };
   const rShuffle = (rng, arr) => { const a=[…arr]; for(let i=a.length-1;i>0;i–){const j=Math.floor(rng()*(i+1));[a[i],a[j]]=[a[j],a[i]];} return a; };

