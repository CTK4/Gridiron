draftPicksMade: {},
playoffResult: null,
ui: { screen: “home”, selectedPlayer: null, modal: null, notification: null }
};

const gameReducer = (state, action) => {
switch (action.type) {
case “INIT_WORLD”: {
const world = generateWorld(action.seed || 42);
return { …state, …world, phase: “ONBOARDING”, onboardingStep: 0 };
}
case “SET_USER_TEAM”: return { …state, userTeamId: action.teamId };
case “SET_COACH_NAME”: return { …state, coachName: action.name };
case “SET_COACH_BACKGROUND”: return { …state, coachBackground: action.bg };
case “SET_ONBOARDING_STEP”: return { …state, onboardingStep: action.step };
case “COMPLETE_ONBOARDING”: {
const { teamId, coachName, background, offScheme, defScheme } = action;
const teams = { …state.teams };
teams[teamId] = { …teams[teamId], offScheme, defScheme, schemeInstall: 60 };
return {
…state, userTeamId: teamId, coachName, coachBackground: background,
teams, phase: “OFFSEASON”,
ui: { …state.ui, screen: “home” }
};
}
case “SIGN_FREE_AGENT”: {
const { playerId, salary, years } = action;
const player = state.players[playerId];
if (!player) return state;
const team = state.teams[state.userTeamId];
const newCapUsed = team.capUsed + salary;
if (newCapUsed > CAP_LIMIT) {
return { …state, ui: { …state.ui, notification: “Not enough cap space!” }};
}
const newPlayers = { …state.players, [playerId]: {
…player, teamId: state.userTeamId,
contract: { salary, years, guaranteed: Math.round(salary * 0.4), tag: false }
}};
const newFAIds = state.freeAgentIds.filter(id => id !== playerId);
const newTeams = { …state.teams, [state.userTeamId]: {
…team,
playerIds: […team.playerIds, playerId],
capUsed: newCapUsed,
capSpace: CAP_LIMIT - newCapUsed,
}};
return {
…state, players: newPlayers, teams: newTeams, freeAgentIds: newFAIds,
transactions: […state.transactions, { type:“SIGNED”, playerId, salary, years, ts:Date.now(),
desc: `Signed ${player.name} (${player.position}) - $${(salary/1e6).toFixed(1)}M/yr`}],
ui: { …state.ui, notification: `Signed ${player.name}!` }
};
}
case “RELEASE_PLAYER”: {
const { playerId } = action;
const player = state.players[playerId];
if (!player || player.teamId !== state.userTeamId) return state;
const team = state.teams[state.userTeamId];
const deadCap = Math.round((player.contract?.guaranteed || 0) * 0.3);
const capRelief = (player.contract?.salary || 0) - deadCap;
const newTeams = { …state.teams, [state.userTeamId]: {
…team,
playerIds: team.playerIds.filter(id => id !== playerId),
capUsed: team.capUsed - capRelief,
capSpace: team.capSpace + capRelief,
}};
const newPlayers = { …state.players, [playerId]: { …player, teamId: null, contract: null }};
return {
…state, players: newPlayers, teams: newTeams,
freeAgentIds: […state.freeAgentIds, playerId],
transactions: […state.transactions, { type:“RELEASED”, playerId, ts:Date.now(), desc:`Released ${player.name}` }],
ui: { …state.ui, notification: `Released ${player.name}`, selectedPlayer: null, modal: null }
};
}
case “DRAFT_PICK”: {
const { prospectId } = action;
const prospect = state.draftClass[prospectId];
if (!prospect) return state;
const salary = Math.max(800_000, Math.round(900_000 * (1 + (78 - prospect.ovr) * 0.01)));
const team = state.teams[state.userTeamId];
const newPlayers = { …state.players, [prospectId]: {
…prospect, isProspect: false, teamId: state.userTeamId,
contract: { salary, years: 4, guaranteed: salary * 2, tag: false }
}};
const newDraftClass = { …state.draftClass };
delete newDraftClass[prospectId];
const newTeams = { …state.teams, [state.userTeamId]: {
…team,
playerIds: […team.playerIds, prospectId],
capUsed: team.capUsed + salary,
capSpace: team.capSpace - salary,
}};
return {
…state, players: newPlayers, draftClass: newDraftClass,
draftClassIds: state.draftClassIds.filter(id => id !== prospectId),
teams: newTeams, draftPicksMade: { …state.draftPicksMade, [prospectId]: true },
transactions: […state.transactions, { type:“DRAFTED”, prospectId, ts:Date.now(),
desc: `Drafted ${prospect.name} (${prospect.position}) - Round ${prospect.round}`}],
ui: { …state.ui, notification: `Drafted ${prospect.name}!` }
};
}
case “SET_SCHEME”: {
const { offScheme, defScheme } = action;
const team = state.teams[state.userTeamId];
const changed = offScheme !== team.offScheme || defScheme !== team.defScheme;
const newInstall = changed ? Math.max(30, (team.schemeInstall || 70) - 20) : team.schemeInstall;
return {
…state,
teams: { …state.teams, [state.userTeamId]: {
…team, offScheme: offScheme || team.offScheme,
defScheme: defScheme || team.defScheme, schemeInstall: newInstall
}}
};
}
case “HIRE_COACH”: {
const { coachId, role } = action;
const coach = state.coaches[coachId];
if (!coach) return state;
const team = state.teams[state.userTeamId];
const fieldMap = { OC: “ocId”, DC: “dcId”, HC: “hcId” };
const oldCoachId = team[fieldMap[role]];
const newCoaches = { …state.coaches, [coachId]: { …coach, teamId: state.userTeamId } };
if (oldCoachId && oldCoachId !== coachId) {
newCoaches[oldCoachId] = { …newCoaches[oldCoachId], teamId: null };
}
return {
…state, coaches: newCoaches,
teams: { …state.teams, [state.userTeamId]: { …team, [fieldMap[role]]: coachId }},
transactions: […state.transactions, { type:“HIRED_COACH”, coachId, ts:Date.now(),
desc: `Hired ${coach.name} as ${role}` }],
ui: { …state.ui, notification: `Hired ${coach.name} as ${role}!` }
};
}
case “ADVANCE_WEEK”: {
if (state.phase !== “REGULAR_SEASON”) return state;
return advanceWeek(state);
}
case “ADVANCE_TO_SEASON”: return { …state, phase: “REGULAR_SEASON”, week: 1 };
case “ADVANCE_TO_PLAYOFFS”: return simulatePlayoffs(state);
case “ADVANCE_TO_NEXT_SEASON”: return rolloverSeason(state);
case “ADVANCE_TO_DRAFT”: return { …state, phase: “DRAFT” };
case “ADVANCE_TO_FA”: return { …state, phase: “FREE_AGENCY” };
case “DISMISS_FA”: return { …state, phase: “DRAFT” };
case “SET_UI”: return { …state, ui: { …state.ui, …action.ui }};
case “CLEAR_NOTIFICATION”: return { …state, ui: { …state.ui, notification: null }};
default: return state;
}
};

