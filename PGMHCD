    newRatings[k] = Math.max(40, Math.min(99, v + delta + (noise === 2 ? 1 : 0)));
  }
  aged.ratings = newRatings;
  aged.ovr = calcOvr(newRatings);
}
newPlayers[id] = aged;
```

}

// Reset team records
for (const teamId of Object.keys(newTeams)) {
newTeams[teamId] = {
…newTeams[teamId],
wins: 0, losses: 0, ties: 0,
pointsFor: 0, pointsAgainst: 0,
confWins: 0, confLosses: 0,
divWins: 0, divLosses: 0,
streak: 0,
};
}

// Generate new draft class
let newDraftClass = {};
for (let round = 1; round <= 7; round++) {
const count = 32;
for (let pick = 0; pick < count; pick++) {
const posIdx = (round - 1) * 4 + (pick % DRAFT_POS_DIST.length);
const pos = DRAFT_POS_DIST[posIdx % DRAFT_POS_DIST.length];
const p = genProspect(s, pos, round);
s = p.nextSeed || (s + 0x13579) | 0;
newDraftClass[p.id] = p;
}
}

// Generate new schedule
const [newSchedule, s2] = genSchedule(s, NFL_TEAMS.map(t => t.id));
s = s2;

// Expire contracts (years -= 1, remove if 0)
const expiredIds = [];
for (const [id, player] of Object.entries(newPlayers)) {
if (!player.contract || player.isProspect) continue;
if (player.contract.years <= 1) {
expiredIds.push(id);
newPlayers[id] = { …player, contract: null, teamId: null };
} else {
newPlayers[id] = { …player, contract: { …player.contract, years: player.contract.years - 1 } };
}
}

// Expired players become FAs
const newFAIds = […state.freeAgentIds, …expiredIds].filter(id => {
const p = newPlayers[id];
return p && !p.teamId && !p.isProspect;
});

// Remove expired from teams
for (const teamId of Object.keys(newTeams)) {
const team = newTeams[teamId];
newTeams[teamId] = { …team, playerIds: team.playerIds.filter(id => newPlayers[id]?.teamId === teamId) };
}

return {
…state,
phase: “OFFSEASON”,
week: 1,
season: state.season + 1,
players: newPlayers,
teams: newTeams,
draftClass: newDraftClass,
draftClassIds: Object.keys(newDraftClass),
freeAgentIds: newFAIds,
schedule: newSchedule,
draftPicksMade: {},
rngSeed: s,
playoffResult: null,
};
};

