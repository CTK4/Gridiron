// Convert compact HCD player record → artifact player shape
const expandPlayer = (p, rng) => {
const ovr = Math.round(p.ovr);
const pot = Math.round(p.pot || p.ovr);
// Synthesize simplified ratings from OVR for display
const spread = (base, d) => Math.max(40, Math.min(99, Math.round(base + (rng()-0.5)*2*d)));
let ratings = {};
const pos = p.pos;
if (pos===“QB”) ratings = {arm:spread(ovr,8),accuracy:spread(ovr,8),iq:spread(ovr,6),mobility:spread(ovr+5,14)};
else if (pos===“HB”) ratings = {speed:spread(ovr+5,8),elusiveness:spread(ovr,8),power:spread(ovr,10),awareness:spread(ovr,6)};
else if (pos===“WR”) ratings = {speed:spread(ovr+3,8),routes:spread(ovr,8),hands:spread(ovr,8),awareness:spread(ovr,6)};
else if (pos===“TE”) ratings = {speed:spread(ovr-5,8),hands:spread(ovr,8),blocking:spread(ovr,10),routes:spread(ovr,8)};
else if (pos===“OL”) ratings = {strength:spread(ovr,8),technique:spread(ovr,8),power:spread(ovr,6),awareness:spread(ovr,6)};
else if (pos===“DE”) ratings = {passRush:spread(ovr+5,8),power:spread(ovr,8),speed:spread(ovr,8),pursuit:spread(ovr,6)};
else if (pos===“DT”) ratings = {power:spread(ovr+3,6),technique:spread(ovr,8),strength:spread(ovr,8),motor:spread(ovr,8)};
else if (pos===“LB”) ratings = {tackling:spread(ovr,8),coverage:spread(ovr,10),blitz:spread(ovr,8),awareness:spread(ovr,6)};
else if (pos===“CB”) ratings = {coverage:spread(ovr+5,8),speed:spread(ovr,6),press:spread(ovr,10),awareness:spread(ovr,8)};
else if (pos===“S”) ratings = {coverage:spread(ovr,8),awareness:spread(ovr+3,6),tackling:spread(ovr,8),speed:spread(ovr,8)};
else ratings = {accuracy:spread(ovr,8),power:spread(ovr,8),consistency:spread(ovr,6),nerves:spread(ovr,6)};

const devTrait = ovr >= 88 ? “generational” : ovr >= 82 ? “elite” : ovr >= 75 ? “impact” : rPick(rng, DEV_TRAITS);
const trait1 = rPick(rng, PLAYER_TRAITS);
const trait2 = rPick(rng, PLAYER_TRAITS.filter(t=>t!==trait1));

return {
id: p.id, name: p.name, position: p.pos,
age: p.age, yearsPro: p.yp, teamId: p.teamId,
ratings, ovr, potential: pot,
contract: { salary: p.sal || 900000, years: p.yrs || 1, guaranteed: Math.round((p.sal||900000)*0.35), tag: false },
status: “healthy”,
traits: [trait1, trait2],
developmentTrait: devTrait,
archetype: p.arch || “”,
morale: 75 + Math.round(rng()*20),
schemeFit: {}, gamesPlayed: 0,
};
};

const genCoach = (rng, type, teamId) => {
const name = `${rPick(rng,COACH_FIRST)} ${rPick(rng,COACH_LAST)}`;
const id = `c_${teamId}_${type}`;
const prefOff = rPick(rng, OFF_SCHEMES);
const prefDef = rPick(rng, DEF_SCHEMES);
const salaryMap = { HC:8_000_000, OC:4_000_000, DC:4_000_000 };
return {
id, name, type, age: rI(rng,38,66), experience: rI(rng,5,28), teamId,
traits: { development: rI(rng,52,95), playcalling: rI(rng,52,95), riskAppetite: rI(rng,32,90), loyalty: rI(rng,42,95) },
preferredOffScheme: type===“OC” ? prefOff.id : null,
preferredDefScheme: type===“DC” ? prefDef.id : null,
contract: { salary: salaryMap[type] + rI(rng,-500000,1500000), years: rI(rng,2,5) },
};
};

const genSchedule = (rng, teamIds) => {
const schedule = [];
for (let week = 1; week <= 18; week++) {
const shuffled = rShuffle(rng, […teamIds]);
const games = [];
for (let i = 0; i < shuffled.length; i += 2) {
if (i+1 < shuffled.length) {
games.push({ home: shuffled[i], away: shuffled[i+1], homeScore: null, awayScore: null, played: false, week });
}
}
schedule.push(games);
}
return schedule;
};

const loadWorldFromData = (seed) => {
const rng = makeRng(seed);

// ── Build players from HCD data ──────────────────────────────
const allPlayers = {};
const teamPlayerMap = {};  // teamId → [playerIds]

// Active roster players
for (const p of HCD_DATA.players) {
const player = expandPlayer(p, rng);
allPlayers[player.id] = player;
if (!teamPlayerMap[p.teamId]) teamPlayerMap[p.teamId] = [];
teamPlayerMap[p.teamId].push(player.id);
}

// Free agents
const freeAgentIds = [];
for (const p of HCD_DATA.fa) {
const player = expandPlayer({ …p, teamId: null, sal: 0, yrs: 0 }, rng);
player.teamId = null;
allPlayers[player.id] = player;
freeAgentIds.push(player.id);
}

// Draft class with fog-of-war
const draftClass = {};
for (const p of HCD_DATA.dc) {
const noiseOvr = Math.max(40, Math.min(99, Math.round(p.tOvr + (rng()-0.5)*16)));
draftClass[p.id] = {
id: p.id, name: p.name, position: p.pos,
age: 22, yearsPro: 0, teamId: null,
ratings: {}, ovr: p.tOvr, potential: p.tOvr + rI(rng,0,8),
contract: { salary: 900000, years: 4, guaranteed: 2000000, tag: false },
status: “healthy”, traits: [rPick(rng,PLAYER_TRAITS)], developmentTrait: rPick(rng,DEV_TRAITS),
archetype: “”, morale: 80, schemeFit: {}, gamesPlayed: 0,
scoutOvr: noiseOvr, scoutGrade: p.grade,
scoutConfidence: Math.max(15, 55 - p.round * 7),
isProspect: true, round: p.round, college: p.col, rank: p.rank,
};
}

// ── Build teams ─────────────────────────────────────────────
const teams = {};
for (let i = 0; i < HCD_DATA.teams.length; i++) {
const t = HCD_DATA.teams[i];
const playerIds = teamPlayerMap[t.id] || [];
const capUsed = playerIds.reduce((sum, pid) => sum + (allPlayers[pid]?.contract?.salary || 0), 0);
const offIdx = ((Math.round(rng()*1000)) % OFF_SCHEMES.length + OFF_SCHEMES.length) % OFF_SCHEMES.length;
const defIdx = ((Math.round(rng()*1000)) % DEF_SCHEMES.length + DEF_SCHEMES.length) % DEF_SCHEMES.length;
teams[t.id] = {
id: t.id, abbr: t.abbr, name: t.name, conf: t.conf, div: t.div,
primary: t.p, secondary: t.s,
playerIds,
wins:0, losses:0, ties:0, pointsFor:0, pointsAgainst:0,
confWins:0, confLosses:0, divWins:0, divLosses:0, streak:0,
capUsed, capSpace: CAP_LIMIT - capUsed,
offScheme: OFF_SCHEMES[offIdx].id,
defScheme: DEF_SCHEMES[defIdx].id,
schemeInstall: 60 + rI(rng, 0, 30),
hcId: null, ocId: null, dcId: null,
draftPickSlot: i + 1,
};
}

// ── Generate coaching staffs ─────────────────────────────────
const coaches = {};
for (const t of HCD_DATA.teams) {
for (const type of [“HC”,“OC”,“DC”]) {
const c = genCoach(rng, type, t.id);
