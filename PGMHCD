const calcTeamStrength = (teamId, state) => {
const team = state.teams[teamId];
const teamPlayers = team.playerIds.map(id => state.players[id]).filter(Boolean);
if (!teamPlayers.length) return { off: 65, def: 65 };

const offPlayers = teamPlayers.filter(p => OFF_POS.includes(p.position));
const defPlayers = teamPlayers.filter(p => DEF_POS.includes(p.position));

const avgOvr = (arr) => arr.length ? arr.reduce((s,p) => s + (p.ovr||65), 0) / arr.length : 65;

let offStr = avgOvr(offPlayers);
let defStr = avgOvr(defPlayers);

// Scheme install bonus (max +5 at 100%)
const installBonus = ((team.schemeInstall || 70) - 50) / 50 * 5;
offStr += installBonus;
defStr += installBonus;

// Coach bonus
const oc = team.ocId && state.coaches[team.ocId];
const dc = team.dcId && state.coaches[team.dcId];
if (oc) offStr += (oc.traits.playcalling - 70) / 30 * 3;
if (dc) defStr += (dc.traits.playcalling - 70) / 30 * 3;

return { off: Math.max(40, Math.min(99, offStr)), def: Math.max(40, Math.min(99, defStr)) };
};

const simulateGame = (homeId, awayId, state, seed) => {
let s = seed;
const home = calcTeamStrength(homeId, state);
const away = calcTeamStrength(awayId, state);

const calcScore = (offense, defense, isHome) => {
const base = 21;
const offMod = (offense - 70) / 30 * 14;
const defMod = (defense - 70) / 30 * -10;
const homeMod = isHome ? 2.5 : 0;
const [variance, ns] = rngNorm(s, 0, 9); s = ns;
return [Math.max(0, Math.round(base + offMod + defMod + homeMod + variance)), s];
};

const [homeScore, s2] = calcScore(home.off, away.def, true); s = s2;
const [awayScore, s3] = calcScore(away.off, home.def, false); s = s3;

// Overtime chance
let finalHome = homeScore, finalAway = awayScore;
if (homeScore === awayScore) {
const [otWinner] = rngBool(s, 0.5); s = (s + 1) | 0;
if (otWinner) finalHome += 3; else finalAway += 3;
}

return { homeScore: finalHome, awayScore: finalAway, nextSeed: s };
};

const advanceWeek = (state) => {
const { week, season, schedule, teams, rngSeed } = state;
let s = rngSeed;
const weekIdx = week - 1;
if (weekIdx < 0 || weekIdx >= schedule.length) return state;

const games = schedule[weekIdx];
const newSchedule = schedule.map((wk, i) => {
if (i !== weekIdx) return wk;
return wk.map(game => {
if (game.played) return game;
const result = simulateGame(game.home, game.away, state, s);
s = result.nextSeed;
return { …game, homeScore: result.homeScore, awayScore: result.awayScore, played: true };
});
});

// Update standings
const newTeams = { …teams };
for (const game of newSchedule[weekIdx]) {
if (!game.played) continue;
const h = { …newTeams[game.home] };
const a = { …newTeams[game.away] };
h.pointsFor += game.homeScore; h.pointsAgainst += game.awayScore;
a.pointsFor += game.awayScore; a.pointsAgainst += game.homeScore;

```
const hDiv = h.div; const aDiv = a.div;
const hConf = h.conf; const aConf = a.conf;
const sameDiv = hDiv === aDiv && hConf === aConf;
const sameConf = hConf === aConf;

if (game.homeScore > game.awayScore) {
  h.wins++; a.losses++;
  h.streak = (h.streak >= 0 ? h.streak : 0) + 1;
  a.streak = (a.streak <= 0 ? a.streak : 0) - 1;
  if (sameDiv) { h.divWins++; a.divLosses++; }
  if (sameConf) { h.confWins++; a.confLosses++; }
} else if (game.awayScore > game.homeScore) {
  a.wins++; h.losses++;
  a.streak = (a.streak >= 0 ? a.streak : 0) + 1;
  h.streak = (h.streak <= 0 ? h.streak : 0) - 1;
  if (sameDiv) { a.divWins++; h.divLosses++; }
  if (sameConf) { a.confWins++; h.confLosses++; }
} else {
  h.ties++; a.ties++;
}
newTeams[game.home] = h;
newTeams[game.away] = a;
```

}

const newWeek = week + 1;
const isSeasonOver = newWeek > 18;

return {
…state,
week: newWeek,
phase: isSeasonOver ? “PLAYOFFS” : “REGULAR_SEASON”,
schedule: newSchedule,
teams: newTeams,
rngSeed: s,
transactions: […state.transactions, {
type: “WEEK_SIMMED”, week, season, ts: Date.now(),
desc: `Week ${week} games complete`
}]
};
};

const simulatePlayoffs = (state) => {
// Seed 7 from each conference, bracket, simulate
const { teams, rngSeed } = state;
let s = rngSeed;

const getSeed = (conf) => {
const confTeams = NFL_TEAMS.filter(t => t.conf === conf).map(t => teams[t.id]);
const sorted = […confTeams].sort((a, b) => {
if (b.wins !== a.wins) return b.wins - a.wins;
const bPct = b.wins / Math.max(1, b.wins + b.losses);
const aPct = a.wins / Math.max(1, a.wins + a.losses);
return bPct - aPct;
});
return sorted.slice(0, 7);
};

const afcSeeds = getSeed(“AFC”);
const nfcSeeds = getSeed(“NFC”);

const simRound = (teams, seedList) => {
// 1 gets bye, 2v7, 3v6, 4v5
let s_local = s;
const bye = seedList[0];
const round1 = [[seedList[1], seedList[6]], [seedList[2], seedList[5]], [seedList[3], seedList[4]]];
const winners = [bye.id];
for (const [home, away] of round1) {
if (!home || !away) { winners.push(home?.id || away?.id); continue; }
const result = simulateGame(home.id, away.id, state, s_local);
s_local = result.nextSeed;
winners.push(result.homeScore >= result.awayScore ? home.id : away.id);
}
s = s_local;
return winners;
};

const afcDiv = simRound(teams, afcSeeds);
const nfcDiv = simRound(teams, nfcSeeds);

const simTwo = (ids) => {
let s_local = s;
const r1 = simulateGame(ids[0], ids[3], state, s_local); s_local = r1.nextSeed;
const r2 = simulateGame(ids[1], ids[2], state, s_local); s_local = r2.nextSeed;
s = s_local;
return [r1.homeScore >= r1.awayScore ? ids[0] : ids[3], r2.homeScore >= r2.awayScore ? ids[1] : ids[2]];
};

const [afcChamp1, afcChamp2] = simTwo(afcDiv);
const [nfcChamp1, nfcChamp2] = simTwo(nfcDiv);

const afcFinal = simulateGame(afcChamp1, afcChamp2, state, s); s = afcFinal.nextSeed;
const nfcFinal = simulateGame(nfcChamp1, nfcChamp2, state, s); s = nfcFinal.nextSeed;

const sbHome = afcFinal.homeScore >= afcFinal.awayScore ? afcChamp1 : afcChamp2;
const sbAway = nfcFinal.homeScore >= nfcFinal.awayScore ? nfcChamp1 : nfcChamp2;

const sbResult = simulateGame(sbHome, sbAway, state, s); s = sbResult.nextSeed;
const champion = sbResult.homeScore >= sbResult.awayScore ? sbHome : sbAway;

const userTeam = state.teams[state.userTeamId];
const userWon = champion === state.userTeamId;
const userAdvanced = [afcChamp1, afcChamp2, nfcChamp1, nfcChamp2].includes(state.userTeamId);

return {
…state,
phase: “OFFSEASON”,
week: 1,
season: state.season + 1,
rngSeed: s,
playoffResult: { champion, sbHome, sbAway, userWon, userAdvanced },
history: […(state.history || []), {
season: state.season,
wins: userTeam.wins,
losses: userTeam.losses,
champion,
userWon,
}],
transactions: […state.transactions, { type:“SEASON_END”, season:state.season, champion, desc:`${teams[champion]?.name || "?"} win the championship!`, ts:Date.now() }]
};
};

const rolloverSeason = (state) => {
let s = state.rngSeed;
const newPlayers = { …state.players };
const newTeams = { …state.teams };

// Age all players, apply progression/regression
for (const [id, player] of Object.entries(newPlayers)) {
if (!player || player.isProspect) continue;
const aged = { …player, age: player.age + 1, yearsPro: player.yearsPro + 1 };
const [progChance] = rngF(s); s = (s + 1) | 0;

```
